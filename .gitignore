# ============================
# AI News Digest - .gitignore
# ============================

# --------------------
# Dependencies
# --------------------
# Node.js/npm dependencies
node_modules/
.pnp
.pnp.js

# --------------------
# Build outputs
# --------------------
# Rust build output
target/
# 注意：Cargo.lock 应该保留在仓库中，用于锁定依赖版本
# Cargo.lock

# Frontend build output
dist/
build/
*.tgz

# Vite dev server cache
.vite/
.eslintcache

# --------------------
# Environment variables
# --------------------
# Never commit API keys, tokens, secrets
.env
.env.local
.env.production
.env.*.local

# --------------------
# IDE & Editor
# --------------------
# VS Code
.vscode/
!.vscode/extensions.json
*.code-workspace

# JetBrains IDEs
.idea/
*.iml

# Sublime Text
*.sublime-*

# --------------------
# OS generated files
# --------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# --------------------
# Logs
# --------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --------------------
# Test & Coverage
# --------------------
coverage/
.nyc_output/

# --------------------
# Temporary files
# --------------------
*.tmp
*.temp
*.swp
*.swo
*~

# --------------------
# Database
# --------------------
# Local database files (if any)
*.db
*.sqlite
*.sqlite3

# --------------------
# Tauri specific
# --------------------
# Generated by Tauri
src-tauri/gen/
# 注意：icons 目录必须保留，包含应用图标
# src-tauri/icons/

# --------------------
# Security Extensions (Additional)
# --------------------
# 特定敏感配置文件
secrets.json
secrets.yaml
secrets.toml
auth.json
config.local.*

# 证书与密钥
*.pem
*.key
*.pub
*.pfx
*.p12
id_rsa
id_rsa.pub

